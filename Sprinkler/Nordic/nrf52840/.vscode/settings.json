    },
    {
      "label": "$(rocket) Clean Build",
      "task": "Clean Build",
      "color": "default",
      "alignment": "left"
    },
    {
      "label": "$(rocket) Flash",
      "task": "Flash",
      "color": "default",
      "alignment": "left"
    },
    {
      "label": "$(rocket) Start OpenOCD Server",
      "task": "Start OpenOCD Server",
      "color": "default",
      "alignment": "left"
    }
  ]
}
