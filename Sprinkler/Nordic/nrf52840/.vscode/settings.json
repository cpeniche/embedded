{
  "cortex-debug.variableUseNaturalFormat": false,
  "files.associations": {
    "ff_gen_drv.h": "c",
    "functional": "c",
    "*.xc": "cpp",
    "*.tcc": "c",
    "bitset": "c",
    "typeinfo": "c",
    "array": "c",
    "string": "c",
    "string_view": "c",
    "initializer_list": "c",
    "regex": "c",
    "cryptography.h": "c"
  },
  "C_Cpp.default.compilerPath": "/home/vscode/zephyr-sdk-0.17.0/arm-zephyr-eabi/bin/arm-zephyr-eabi-gcc",
  "cmake.sourceDirectory": "/home/vscode/project/app",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
